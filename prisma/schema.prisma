// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  password  String
  name      String
  department String?
  role      String   @default("USER") // ADMIN, AUDITOR, USER, GUEST
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cpasCreated Cpa[] @relation("CpaAuthor")
  cpasAssigned Cpa[] @relation("CpaAssignee")
  audits     Audit[]
  risks      Risk[]
  documentsCreated  Document[] @relation("DocAuthor")
  documentsReviewed Document[] @relation("DocReviewer")
  complaints Complaint[]
  objectives Objective[]
  devices    Device[]
}

model Cpa {
  id          String   @id @default(cuid())
  source      String   // İç Denetim, Müşteri Şikayeti, Süreç İçi
  department  String
  description String
  rootCause   String?
  actionPlan  String?
  resolutionNote String?
  status      String   @default("AÇIK") // AÇIK, İŞLEMDE, KAPALI
  authorId    String?
  author      User?    @relation("CpaAuthor", fields: [authorId], references: [id])
  assigneeId  String?
  assignee    User?    @relation("CpaAssignee", fields: [assigneeId], references: [id])
  targetDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Audit {
  id          String   @id @default(cuid())
  title       String
  department  String   @default("Genel")
  date        DateTime
  auditor     String
  status      String   @default("PLANLANDI") // PLANLANDI, DEVAM_EDİYOR, TAMAMLANDI
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Risk {
  id          String   @id @default(cuid())
  code        String   @unique
  process     String
  description String
  score       Int
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        String   // Prosedür, Form, El Kitabı
  revision    String
  publishDate DateTime
  fileUrl     String?
  status      String   @default("ONAY_BEKLİYOR") // ONAY_BEKLİYOR, YAYINLANDI
  authorId    String?
  author      User?    @relation("DocAuthor", fields: [authorId], references: [id])
  reviewerId  String?
  reviewer    User?    @relation("DocReviewer", fields: [reviewerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Complaint {
  id          String   @id @default(cuid())
  customer    String
  description String
  status      String   @default("YENİ") // YENİ, İNCELENİYOR, ÇÖZÜLDÜ
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Objective {
  id          String   @id @default(cuid())
  title       String
  targetValue Float
  actualValue Float
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id               String   @id @default(cuid())
  message          String
  targetDepartment String
  isRead           Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SystemOption {
  id        String   @id @default(cuid())
  category  String   // e.g., "DEPARTMENT", "DOC_TYPE", "CPA_SOURCE"
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([category, value]) // Prevent duplicate values in the same category
}

model Device {
  id                  String   @id @default(cuid())
  name                String
  serialNo            String?
  calibrationDate     DateTime
  nextCalibrationDate DateTime
  status              String   @default("AKTİF") // AKTİF, PASİF, KALİBRASYON_DIŞI
  authorId            String?
  author              User?    @relation(fields: [authorId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
